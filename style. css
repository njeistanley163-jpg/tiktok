* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: system-ui, sans-serif; background: #000; color: #fff; overflow: hidden; }

.app { max-width: 1200px; margin: 0 auto; height: 100vh; display: flex; flex-direction: column; }

header {
    background: rgba(0,0,0,0.95); padding: 10px 15px; display: flex; align-items: center; position: fixed; width: 100%; z-index: 100;
}
.logo { font-size: 28px; font-weight: 900; color: #fe2c55; }
.search { flex: 1; margin: 0 15px; }
.search input { width: 100%; padding: 8px 15px; border-radius: 999px; background: #222; border: none; color: white; }

.main { flex: 1; overflow-y: scroll; margin-top: 60px; scroll-snap-type: y mandatory; }
.feed { scroll-snap-type: y mandatory; }

.video-wrapper {
    height: 100vh; position: relative; scroll-snap-align: start; background: #111;
}
video { width: 100%; height: 100%; object-fit: cover; }

.bottom-nav {
    position: fixed; bottom: 0; width: 100%; background: #111; display: flex; justify-content: space-around; padding: 8px 0; font-size: 26px; z-index: 100;
}

.modal {
    display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); align-items: center; justify-content: center; z-index: 1000;
}
.modal-content { background: #111; padding: 30px; border-radius: 15px; width: 90%; max-width: 380px; }
